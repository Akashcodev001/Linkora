# -----------------------------
# Workspace-level ignores
# -----------------------------

# Dependency directories
node_modules/
**/node_modules/

# Build outputs
build/
dist/
**/dist/
**/dist-ssr/

# Test / coverage artifacts
coverage/
**/coverage/
.nyc_output/

# Runtime and logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and local secrets
.env
.env.*
.env-example
.env.example
**/.env
**/.env.*
**/.env-example
**/.env.example
*.local

# Cache and temp files
.cache/
.tmp/
tmp/
.temp/
.eslintcache
*.tsbuildinfo

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Docker local state
**/.docker/

# Optional local reports / notes (keep out of git if regenerated locally)
DEPLOYMENT_READY.md
