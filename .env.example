# Deployment environment variables for docker-compose
# Copy this file to .env at repository root and replace values.

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/Linkora?retryWrites=true&w=majority

# Security
JWT_SECRET=REPLACE_WITH_STRONG_64PLUS_CHAR_SECRET
AI_SERVICE_INTERNAL_KEY=REPLACE_WITH_STRONG_64PLUS_CHAR_SECRET

# Optional AI provider keys
MISTRAL_API_KEY=
