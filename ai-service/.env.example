# AI Service Environment Variables
# Copy this file to .env locally and fill in your values

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/Linkora?retryWrites=true&w=majority

# Redis (same as Backend)
REDIS_URL=redis://localhost:6379

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenAI API
OPENAI_API_KEY=your_openai_api_key

# Mistral API (for tags generation)
MISTRAL_API_KEY=your_mistral_api_key

# Internal Security
AI_SERVICE_INTERNAL_KEY=REPLACE_WITH_STRONG_64PLUS_CHAR_SECRET

# Server
AI_SERVICE_PORT=5001

# Logging
LOG_LEVEL=info
